ratio_data_filtered = ratio_data %>% select(-MFAP5_GDF15, -MFAP5_GLB1, -MFAP5_P16, -MFAP5_P21, -MFAP5)



# 2. Extract the column to be used as row names
#    It's good practice to store this separately first.
row_labels <- ratio_data_filtered$cell_type

# 3. Convert the numeric part of the dataframe to a matrix
#    We use `select(-GeneID)` to exclude the GeneID column before converting.
data_matrix_for_heatmap <- ratio_data_filtered %>%
  select(-cell_type) %>% # Exclude the column you want to use as row names
  as.matrix()         # Convert the remaining numeric data to a matrix

# 4. Assign the extracted row labels to the matrix
rownames(data_matrix_for_heatmap) <- row_labels

# Now, data_matrix_for_heatmap is ready for pheatmap
print(head(data_matrix_for_heatmap)) # Check the matrix with its new row names


