ratio_data = readxl::read_xlsx("Y:\\Senescence_paper\\tentative_metadata\\tentative_metadata\\positive_ratio_table.xlsx")

library(pheatmap)


pkgs <- as.data.frame(installed.packages()[, c("Package", "Version")])
