```{r setup, message=FALSE, warning=FALSE}
###############################################################
# Plasticity Gene Validation Heatmap
#
# Purpose:
# Cross-validation of epithelial plasticity-associated genes
# using integrated pediatric lung snRNA-seq data.
#
# Plasticity genes were selected based on developmental
# epithelial states reported by He et al.
#
# Dataset:
# lungQuery_After_AZ_Normalized.rds
#
# Groups:
# PT_NEWBORN
# FT_NEWBORN
# PT_BPD
#
# Outputs:
# PlasticityGenes_RawAverageExpression.csv
# PlasticityGenes_RowZscore.csv
# PlasticityGenes_PLOTTED_MATRIX.csv
# PlasticityGenes_Heatmap.pdf
# sessionInfo.txt
###############################################################

library(Seurat)
library(Matrix)
library(pheatmap)
```

## Load Seurat object

```{r load-object}
obj <- readRDS("lungQuery_After_AZ_Normalized.rds")

stopifnot("Donor_Group" %in% colnames(obj@meta.data))
```

## Define plasticity genes

```{r define-genes}
# Plasticity / reprogramming genes
  "KLF4",
  "POU5F1",
  "MYC",
  "MYCBP2",
  "SOX2",
  "HDAC3",
  "CTNNB1",
  "EP300",
  "CEBPB",
  "ID2",

  # Epithelial / transitional markers
  "KMT2A",
  "KRT7",
  "KRT8",

  # Senescence-associated genes
  "CDKN1A",
  "CDKN2A",
  "TP53",
  "GDF15",
  "IL6ST",
  "CXCL8",
  "SERPINE1",

  # Growth factor / signaling genes
  "FGF10",
  "FGFR2",
  "BMP4",
  "TGFB1",
  "PDGFA",
  "IGF2"
)
```

## Define groups

```{r define-groups}
stage_order <- c(
  "PT_NEWBORN",
  "FT_NEWBORN",
  "PT_BPD"
)
```

## Subset object

```{r subset-object}
obj_use <- subset(
  obj,
  subset = Donor_Group %in% stage_order
)

DefaultAssay(obj_use) <- "RNA"
```

## Extract normalized RNA expression

```{r extract-expression}
expr_mat <- GetAssayData(
  obj_use,
  assay = "RNA",
  layer = "data"
)
```

## Keep genes present in dataset

```{r check-genes}
genes_use <- plasticity_genes[
  plasticity_genes %in% rownames(expr_mat)
]

genes_missing <- plasticity_genes[
  !plasticity_genes %in% rownames(expr_mat)
]

print("Genes used:")
print(genes_use)

print("Genes missing:")
print(genes_missing)

if (length(genes_use) == 0) {
  stop("None of the selected plasticity genes were found in the dataset.")
}
```

## Average expression by group

```{r average-expression}
expr_sub <- expr_mat[genes_use, , drop = FALSE]

meta <- obj_use@meta.data
meta <- meta[colnames(expr_sub), , drop = FALSE]

avg_exp <- sapply(stage_order, function(stage) {
  cells <- rownames(meta)[meta$Donor_Group == stage]
  Matrix::rowMeans(expr_sub[, cells, drop = FALSE])
})

avg_exp <- as.matrix(avg_exp)

colnames(avg_exp) <- c(
  "PT-NB",
  "FT-NB",
  "PT-BPD"
)
```

## Row z-score

```{r row-zscore}
avg_z <- t(scale(t(avg_exp)))

avg_z <- avg_z[
  complete.cases(avg_z),
  ,
  drop = FALSE
]
```

## Clip z-scores for plotting

```{r clip-zscore}
avg_z_clip <- avg_z

avg_z_clip[avg_z_clip > 2] <- 2
avg_z_clip[avg_z_clip < -2] <- -2
```

## Plot heatmap

```{r plot-heatmap, fig.width=5, fig.height=4}
pheatmap(
  avg_z_clip,
  cluster_rows = FALSE,
  cluster_cols = FALSE,
  border_color = "black",
  color = colorRampPalette(
    c("#FFFFCC", "white", "#9B1B9E")
  )(100),
  breaks = seq(-2, 2, length.out = 101),
  legend_breaks = c(-2, -1, 0, 1, 2),
  legend_labels = c("-2", "-1", "0", "1", "2"),
  fontsize_row = 14,
  fontsize_col = 12,
  cellwidth = 38,
  cellheight = 32,
  angle_col = 45,
  main = "Plasticity genes in pediatric lung groups"
)
```

## Save heatmap as PDF

```{r save-heatmap}
pdf(
  "PlasticityGenes_Heatmap.pdf",
  width = 5,
  height = 4
)

pheatmap(
  avg_z_clip,
  cluster_rows = FALSE,
  cluster_cols = FALSE,
  border_color = "black",
  color = colorRampPalette(
    c("#FFFFCC", "white", "#9B1B9E")
  )(100),
  breaks = seq(-2, 2, length.out = 101),
  legend_breaks = c(-2, -1, 0, 1, 2),
  legend_labels = c("-2", "-1", "0", "1", "2"),
  fontsize_row = 14,
  fontsize_col = 12,
  cellwidth = 38,
  cellheight = 32,
  angle_col = 45,
  main = "Plasticity genes in pediatric lung groups"
)

dev.off()
```

## Export source matrices

```{r export-source-data}
write.csv(
  avg_exp,
  "PlasticityGenes_RawAverageExpression.csv"
)

write.csv(
  avg_z,
  "PlasticityGenes_RowZscore.csv"
)

write.csv(
  avg_z_clip,
  "PlasticityGenes_PLOTTED_MATRIX.csv"
)
```

